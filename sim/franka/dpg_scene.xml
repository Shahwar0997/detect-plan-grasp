<mujoco model="dpg grasp scene">
  <!-- Franka Panda (arm + hand + actuators + 'home' keyframe). Sits beside panda.xml so its
       meshdir="assets" resolves. Meshes are gitignored; restore with sim/fetch_assets.sh. -->
  <include file="panda.xml"/>

  <statistic center="0.4 0 0.3" extent="1.1"/>
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.4 0.4 0.4" specular="0 0 0"/>
    <global azimuth="140" elevation="-25"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.45 0.6 0.8" rgb2="0.1 0.15 0.25"
             width="512" height="512"/>
    <material name="tablemat" rgba="0.55 0.42 0.30 1"/>
    <material name="objmat" rgba="0.85 0.20 0.15 1"/>
  </asset>

  <worldbody>
    <light pos="0.5 0 1.6" dir="0 0 -1" directional="true"/>
    <geom name="floor" type="plane" size="0 0 0.05" rgba="0.3 0.35 0.4 1"/>

    <!-- table in front of the arm; top surface at z = 0.30 -->
    <geom name="table" type="box" pos="0.5 0 0.15" size="0.25 0.35 0.15" material="tablemat"/>

    <!-- a graspable block on the table: 5 cm wide (< 8 cm gripper), short enough to be
         stable, tall enough to grip clear of the table -->
    <body name="object" pos="0.5 0 0.335">
      <freejoint/>
      <geom name="object_geom" type="box" size="0.025 0.025 0.035" material="objmat" mass="0.1"
            friction="1.5 0.1 0.001"/>
    </body>

    <!-- RGB-D camera looking down at the table from the front-left -->
    <camera name="cam" pos="0.5 -0.55 0.85" xyaxes="1 0 0 0 0.75 0.66"/>
  </worldbody>
</mujoco>
